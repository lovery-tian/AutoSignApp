<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF1A1A2E"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="云班课自动签到"
            android:textColor="#FFFFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="状态: 未启动"
            android:textColor="#FFB0B0B0"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- 登录卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="账号设置"
                android:textColor="#FF4CAF50"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/etUsername"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="手机号 / 邮箱"
                android:textColorHint="#FF666666"
                android:textColor="#FFFFFFFF"
                android:textSize="15sp"
                android:inputType="text"
                android:background="@drawable/bg_input"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="10dp"
                android:singleLine="true" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="10dp">

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="密码"
                    android:textColorHint="#FF666666"
                    android:textColor="#FFFFFFFF"
                    android:textSize="15sp"
                    android:inputType="textPassword"
                    android:background="@drawable/bg_input"
                    android:paddingStart="14dp"
                    android:paddingEnd="48dp"
                    android:singleLine="true" />

                <ImageButton
                    android:id="@+id/btnTogglePassword"
                    android:layout_width="48dp"
                    android:layout_height="match_parent"
                    android:layout_alignParentEnd="true"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_view"
                    android:scaleType="centerInside"
                    android:contentDescription="显示密码"
                    android:tint="#FF888888" />
            </RelativeLayout>

            <Button
                android:id="@+id/btnWebViewLogin"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="WebView登录（推荐）"
                android:textColor="#FFFFFFFF"
                android:textSize="14sp"
                android:backgroundTint="#FF2196F3"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- 开关卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="自动签到"
                    android:textColor="#FFFFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSwitchHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="打开后自动检测并完成签到"
                    android:textColor="#FF888888"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <Switch
                android:id="@+id/switchAutoSign"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#FF4CAF50"
                android:trackTint="#FF333333" />
        </LinearLayout>

        <!-- 课程列表 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="监控课程"
                android:textColor="#FF4CAF50"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvCourses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="登录后自动加载..."
                android:textColor="#FFB0B0B0"
                android:textSize="13sp"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

        <!-- 日志 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="运行日志"
                android:textColor="#FF4CAF50"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="200dp">

                <TextView
                    android:id="@+id/tvLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="等待启动..."
                    android:textColor="#FF888888"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="3dp" />
            </ScrollView>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="仅供学习交流，请合理使用"
            android:textColor="#FF444444"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_marginTop="16dp" />

    </LinearLayout>
</ScrollView>
